# 卡咔本地配置模板。
# Copy this file to ".env" and fill in real local values.
# Never commit ".env"; it contains secrets.

# Enable remote LLM calls. Set to false to run with fallback replies only.
LLM_ENABLED=true

# DeepSeek API key. Replace this placeholder in your local ".env".
LLM_API_KEY=replace-with-your-deepseek-api-key

# DeepSeek OpenAI-compatible API base URL.
LLM_BASE_URL=https://api.deepseek.com

# Main chat model.
# If your account does not provide deepseek-v4-flash, use deepseek-chat.
LLM_CHAT_MODEL=deepseek-v4-flash

# Reserved model roles for later routing.
# If your account does not provide deepseek-v4-pro, use deepseek-reasoner.
LLM_REASONING_MODEL=deepseek-v4-pro
LLM_MEMORY_MODEL=deepseek-v4-flash
LLM_TOOL_MODEL=deepseek-v4-flash

# Generation options.
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=800
LLM_REQUEST_TIMEOUT=60

# Automatic memory candidate analysis.
# When enabled, kaka-core checks at the next full hour and then every full hour.
# It runs only when not_analyzed inputs reach the trigger count.
# Set MEMORY_AUTO_ANALYSIS_INTERVAL_SECONDS > 0 for short-interval local testing.
MEMORY_AUTO_ANALYSIS_ENABLED=false
MEMORY_AUTO_ANALYSIS_TRIGGER_COUNT=50
MEMORY_AUTO_ANALYSIS_BATCH_LIMIT=50
MEMORY_AUTO_ANALYSIS_MAX_RUNS_PER_CHECK=2
MEMORY_AUTO_ANALYSIS_INTERVAL_SECONDS=0

# Automatic pending memory candidate review.
# When enabled, kaka-core checks at the next full hour and then every full hour.
# It starts only when pending candidates reach the trigger count.
MEMORY_AUTO_REVIEW_ENABLED=false
MEMORY_AUTO_REVIEW_TRIGGER_COUNT=20
MEMORY_AUTO_REVIEW_BATCH_SIZE=10
MEMORY_AUTO_REVIEW_MAX_RUNS_PER_CHECK=1

# Long-term memories used when generating chat replies.
# Keep this enabled only after memories quality is acceptable.
MEMORY_REPLY_INJECTION_ENABLED=true
MEMORY_REPLY_LIMIT=5
MEMORY_REPLY_MIN_SCORE=1.0
MEMORY_REPLY_POOL_SIZE=300

# Persona prompt used as the base System Prompt before dynamic context is appended.
KAKA_PERSONA_PROMPT_PATH=prompts/kaka_persona.md

# Recent same-scene messages used when generating chat replies.
SHORT_CONTEXT_ENABLED=true
SHORT_CONTEXT_LIMIT=20
SHORT_CONTEXT_MAX_CHARS=1200
SHORT_CONTEXT_WINDOW_MINUTES=30

# Relationship context used when generating chat replies.
# Use QQ user IDs. Separate multiple owners with commas.
KAKA_OWNER_USER_IDS=

# Local SQLite database.
DATABASE_URL=sqlite:///./data/kaka.sqlite3

# Plugin runtime.
# Keep disabled unless you are testing explicit plugin commands.
# Example command: 插件：n8n github_weekly_stars
PLUGIN_SYSTEM_ENABLED=false
PLUGIN_COMMAND_PREFIXES=插件：,插件:,plugin:
PLUGIN_N8N_WEBHOOK_BASE_URL=http://127.0.0.1:5678/webhook/kaka
PLUGIN_N8N_WEBHOOK_TIMEOUT=30

# Local admin console and /admin/api protection.
# Keep local-only enabled unless you put kaka-core behind a trusted reverse proxy.
# If ADMIN_LOCAL_ONLY=false, ADMIN_API_TOKEN must be set and sent as X-Kaka-Admin-Token.
ADMIN_LOCAL_ONLY=true
ADMIN_API_TOKEN=

# QQ adapter -> 卡咔核心.
KAKA_CORE_BASE_URL=http://127.0.0.1:8001
QQ_ADAPTER_REQUEST_TIMEOUT=60

# Desktop pet -> 卡咔核心.
# By default the desktop pet reads KAKA_CORE_BASE_URL and uses the first
# KAKA_OWNER_USER_IDS value as desktop user_id when available.
KAKA_DESKTOP_CORE_ADDR=
KAKA_DESKTOP_CORE_HOST_HEADER=
KAKA_DESKTOP_USER_ID=
KAKA_DESKTOP_DISPLAY_NAME=Local User
KAKA_DESKTOP_SCENE_ID=desktop-local

# External proactive notifications from n8n or other workflows.
# Use a local random value and send it as Authorization: Bearer <token>.
PLUGIN_NOTIFICATION_TOKEN=<replace-with-local-notification-token>
PLUGIN_NOTIFICATION_ADAPTER_TIMEOUT=30

# kaka-core -> QQ adapter proactive send API.
QQ_ADAPTER_SEND_BASE_URL=http://127.0.0.1:8081/proactive
QQ_ADAPTER_SEND_TOKEN=<replace-with-local-qq-send-token>

# n8n GitHub project radar workflow.
# GITHUB_TOKEN is optional but recommended for stable GitHub Search API limits.
# If n8n runs in Docker, pass these values into the n8n container env.
# For Docker on Windows, set KAKA_CORE_BASE_URL=http://host.docker.internal:8001
# in the n8n container env, and set N8N_BLOCK_ENV_ACCESS_IN_NODE=false so Code nodes can read $env.
GITHUB_TOKEN=
GITHUB_RADAR_SECTION_LIMIT=5
GITHUB_RADAR_ACTIVE_DAYS=30
GITHUB_RADAR_MATURE_MIN_STARS=10000
GITHUB_RADAR_POTENTIAL_MIN_STARS=500
GITHUB_RADAR_POTENTIAL_MAX_STARS=10000
GITHUB_RADAR_GROWTH_MIN_STARS=500
GITHUB_RADAR_GROWTH_CANDIDATE_LIMIT=50
GITHUB_RADAR_FAKE_GROWTH_ON_FIRST_RUN=true
GITHUB_RADAR_TARGET_SCENE_TYPE=group
GITHUB_RADAR_TARGET_SCENE_ID=replace-with-your-qq-group-id

# Backward-compatible fallback for older imported workflows.
GITHUB_WEEKLY_TARGET_SCENE_TYPE=group
GITHUB_WEEKLY_TARGET_SCENE_ID=replace-with-your-qq-group-id
